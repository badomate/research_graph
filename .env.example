# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.
# ──────────────────────────────────────────────

# Notion integration token (starts with "secret_")
NOTION_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Notion database IDs (32-char hex, no dashes)
NOTION_PAPER_TRACKER_DB_ID=your_paper_tracker_db_id_here
NOTION_KNOWLEDGE_INBOX_DB_ID=your_knowledge_inbox_db_id_here
NOTION_SECOND_BRAIN_DB_ID=your_second_brain_db_id_here
NOTION_PROJECTS_DB_ID=your_projects_db_id_here
NOTION_EDGES_DB_ID=your_edges_db_id_here
NOTION_DEFERRED_EDGES_DB_ID=your_defered_edges_db_id_here
# OpenAI API key
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Koofr WebDAV credentials
KOOFR_USER=your_email@example.com
KOOFR_APP_PASSWORD=your_koofr_app_password_here
# Base path inside Koofr where PDFs live
KOOFR_PDF_PATH=/Papers

# ArXiv search settings (comma-separated keywords)
ARXIV_KEYWORDS=Mean Field Games,Master Equation,McKean-Vlasov,Hamilton-Jacobi-Bellman

# Relevance threshold for auto-adding ArXiv papers
ARXIV_RELEVANCE_THRESHOLD=8



GRAPH_SERVER_PORT=8000

# Tag registry and pipeline database
TAGS_REGISTRY_PATH=../tags_registry.yaml
PIPELINE_DB_PATH=/tmp/pipeline/ingestion_jobs.db

# Zotero API 
ZOTERO_USER_ID=your_zotero_user_id_here
ZOTERO_API_KEY=your_zotero_api_key_here
EXTRACTION_VERSION=v3

# Second Brain Note Level value used to query Concept pages (default: Concept)
SB_CONCEPT_LEVEL=Concept

DATALAB_API_KEY=your_maker_api_key_here
MARKER_MODE=balanced          # fast | balanced | accurate

# Local profiles — uncomment and set when using marker-local-cpu or marker-local-gpu:
MARKER_API_URL=http://marker-local:8080

# ── Vector Index (Module 7) ────────────────────────────────────────────────────
# Set to any non-empty value to enable semantic retrieval via Qdrant.
# When disabled the pipeline falls back to TF-IDF token-overlap retrieval.
VECTOR_INDEX_ENABLED=true

# Qdrant REST endpoint (matches the service name in docker-compose.yml).
QDRANT_URL=http://qdrant:6333

# Embedding backend: openai | local
#   openai — uses the OpenAI Embeddings API (requires OPENAI_API_KEY)
#   local  — uses sentence-transformers locally (no API cost, slower cold start)
VECTOR_EMBEDDING_BACKEND=local

# OpenAI embedding model (backend=openai).
# text-embedding-3-small  → 1536 dimensions (default, cost-efficient)
# text-embedding-3-large  → 3072 dimensions (higher quality, higher cost)
VECTOR_EMBEDDING_MODEL=text-embedding-3-small

# Local HuggingFace model (backend=local).
# Requires: pip install sentence-transformers>=2.7.0
# allenai/specter2        → 768 dimensions (domain-trained on scientific papers)
VECTOR_EMBEDDING_MODEL=allenai/specter2

# Embedding dimension — MUST match the model above:
#   text-embedding-3-small  → 1536
#   text-embedding-3-large  → 3072
#   allenai/specter2        → 768
VECTOR_EMBEDDING_DIM=768
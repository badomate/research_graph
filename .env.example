# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.
# ──────────────────────────────────────────────

# Notion integration token (starts with "secret_")
NOTION_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Notion database IDs (32-char hex, no dashes)
NOTION_PAPER_TRACKER_DB_ID=your_paper_tracker_db_id_here
NOTION_KNOWLEDGE_INBOX_DB_ID=your_knowledge_inbox_db_id_here
NOTION_SECOND_BRAIN_DB_ID=your_second_brain_db_id_here
NOTION_PROJECTS_DB_ID=your_projects_db_id_here

# Anthropic API key
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Koofr WebDAV credentials
KOOFR_USER=your_email@example.com
KOOFR_APP_PASSWORD=your_koofr_app_password_here
# Base path inside Koofr where PDFs live
KOOFR_PDF_PATH=/Papers

# ArXiv search settings (comma-separated keywords)
ARXIV_KEYWORDS=Mean Field Games,Master Equation,McKean-Vlasov,Hamilton-Jacobi-Bellman

# Relevance threshold for auto-adding ArXiv papers
ARXIV_RELEVANCE_THRESHOLD=8

# Internal service URLs (used inside Docker network — do not change unless renaming services)
MARKER_API_URL=http://marker-api:8080
GRAPH_SERVER_PORT=8000
